{
  "name": "discord-gs",
  "version": "1.0.0",
  "private": true,
  "description": "A professional Discord Webhook library for Google Apps Script.",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "ci:lint": "eslint .",
    "test": "node src/tests/NodeTests.js",
    "test:node": "node src/tests/NodeTests.js",
    "test:gas": "echo 'Run GasTests.gs manually in the Apps Script Editor.' && exit 0"
  },
  "devDependencies": {
    "@types/google-apps-script": "^1.0.83",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "sync-fetch": "^0.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10"
}
